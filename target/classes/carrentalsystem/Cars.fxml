<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.image.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="carrentalsystem.controllers.CarsController"
      style="-fx-background-color: #060818; -fx-padding: 28;"
      spacing="16">

    <!-- HERO HEADER WITH BACKGROUND IMAGE -->
    <StackPane prefHeight="210"
               minHeight="210"
               maxHeight="210"
               style="-fx-background-color: #0d1224;
                      -fx-background-radius: 18;
                      -fx-border-color: #1a2040;
                      -fx-border-radius: 18;
                      -fx-border-width: 1;
                      -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.28), 20, 0, 0, 8);">

        <ImageView fitWidth="1120"
                   fitHeight="210"
                   preserveRatio="false"
                   smooth="true"
                   opacity="0.95">
            <image>
                <Image url="@images/cars-hero.png"/>
            </image>
        </ImageView>

        <Rectangle width="1120"
                   height="210"
                   fill="#050714"
                   opacity="0.48"
                   arcWidth="36"
                   arcHeight="36"/>

        <Rectangle width="1120"
                   height="210"
                   fill="#0b1d4a"
                   opacity="0.20"
                   arcWidth="36"
                   arcHeight="36"/>

        <VBox spacing="22"
              style="-fx-padding: 24 34 24 34;"
              StackPane.alignment="CENTER">

            <HBox alignment="CENTER_LEFT" spacing="12">

                <VBox spacing="5">
                    <Label text="Cars"
                           style="-fx-font-size: 26px;
                                  -fx-font-weight: bold;
                                  -fx-text-fill: #e6f1ff;"/>

                    <Label text="Manage fleet vehicles, prices, categories, and branch assignment"
                           style="-fx-font-size: 12px;
                                  -fx-text-fill: #c7d2fe;"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <TextField fx:id="txtSearch"
                           promptText="🔍  Search..."
                           onAction="#handleSearch"
                           style="-fx-background-color: rgba(13,18,36,0.88);
                                  -fx-text-fill: #e6f1ff;
                                  -fx-prompt-text-fill: #7783a5;
                                  -fx-border-color: rgba(147,197,253,0.28);
                                  -fx-border-radius: 8;
                                  -fx-background-radius: 8;
                                  -fx-padding: 8 14;
                                  -fx-pref-width: 200;"/>

                <Button text="+ Add"
                        onAction="#handleAdd"
                        style="-fx-background-color: #3d5af1;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-background-radius: 8;
                               -fx-border-width: 0;
                               -fx-padding: 8 18;
                               -fx-cursor: hand;"/>

                <Button text="✏ Edit"
                        onAction="#handleEdit"
                        style="-fx-background-color: rgba(30,58,95,0.90);
                               -fx-text-fill: #93c5fd;
                               -fx-font-weight: bold;
                               -fx-background-radius: 8;
                               -fx-border-width: 0;
                               -fx-padding: 8 18;
                               -fx-cursor: hand;"/>

                <Button text="🗑 Delete"
                        onAction="#handleDelete"
                        style="-fx-background-color: rgba(45,21,21,0.92);
                               -fx-text-fill: #ff6b6b;
                               -fx-font-weight: bold;
                               -fx-background-radius: 8;
                               -fx-border-width: 0;
                               -fx-padding: 8 18;
                               -fx-cursor: hand;"/>
            </HBox>

            <VBox spacing="8">
                <Label text="Fleet Management"
                       style="-fx-text-fill: white;
                              -fx-font-size: 25px;
                              -fx-font-weight: bold;"/>

                <Label text="Add and manage cars with plate numbers, daily prices, categories, and assigned branches."
                       wrapText="true"
                       maxWidth="800"
                       style="-fx-text-fill: #c7d2fe;
                              -fx-font-size: 13px;"/>

                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="●"
                           style="-fx-text-fill: #63e6be;
                                  -fx-font-size: 14px;"/>

                    <Label text="Vehicles · Pricing · Categories · Branches"
                           style="-fx-text-fill: #93c5fd;
                                  -fx-font-size: 12px;"/>
                </HBox>
            </VBox>

        </VBox>
    </StackPane>

    <!-- FORM فوق الجدول -->
    <VBox fx:id="formPanel"
          spacing="14"
          style="-fx-background-color: #0d1224;
                 -fx-border-color: #1a2040;
                 -fx-border-radius: 12;
                 -fx-background-radius: 12;
                 -fx-border-width: 1;
                 -fx-padding: 20;">

        <Label fx:id="lblFormTitle"
               text="Add New Car"
               style="-fx-font-size: 16px;
                      -fx-font-weight: bold;
                      -fx-text-fill: #e6f1ff;"/>

        <HBox spacing="16">
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Plate Number *" style="-fx-text-fill: #ccd6f6; -fx-font-size: 12px;"/>
                <TextField fx:id="txtPlateNumber"
                           promptText="GZ-1001"
                           style="-fx-background-color: #060818; -fx-text-fill: #e6f1ff; -fx-prompt-text-fill: #46506f; -fx-border-color: #1a2040; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10 14;"/>
            </VBox>

            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Brand *" style="-fx-text-fill: #ccd6f6; -fx-font-size: 12px;"/>
                <TextField fx:id="txtBrand"
                           promptText="Toyota"
                           style="-fx-background-color: #060818; -fx-text-fill: #e6f1ff; -fx-prompt-text-fill: #46506f; -fx-border-color: #1a2040; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10 14;"/>
            </VBox>

            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Model *" style="-fx-text-fill: #ccd6f6; -fx-font-size: 12px;"/>
                <TextField fx:id="txtModel"
                           promptText="Yaris"
                           style="-fx-background-color: #060818; -fx-text-fill: #e6f1ff; -fx-prompt-text-fill: #46506f; -fx-border-color: #1a2040; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10 14;"/>
            </VBox>

            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Color" style="-fx-text-fill: #ccd6f6; -fx-font-size: 12px;"/>
                <TextField fx:id="txtColor"
                           promptText="White"
                           style="-fx-background-color: #060818; -fx-text-fill: #e6f1ff; -fx-prompt-text-fill: #46506f; -fx-border-color: #1a2040; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10 14;"/>
            </VBox>
        </HBox>

        <HBox spacing="16">
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Daily Price *" style="-fx-text-fill: #ccd6f6; -fx-font-size: 12px;"/>
                <TextField fx:id="txtDailyPrice"
                           promptText="35.00"
                           style="-fx-background-color: #060818; -fx-text-fill: #e6f1ff; -fx-prompt-text-fill: #46506f; -fx-border-color: #1a2040; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10 14;"/>
            </VBox>

            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Manufacture Year" style="-fx-text-fill: #ccd6f6; -fx-font-size: 12px;"/>
                <TextField fx:id="txtManufactureYear"
                           promptText="2022"
                           style="-fx-background-color: #060818; -fx-text-fill: #e6f1ff; -fx-prompt-text-fill: #46506f; -fx-border-color: #1a2040; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10 14;"/>
            </VBox>

            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Mileage" style="-fx-text-fill: #ccd6f6; -fx-font-size: 12px;"/>
                <TextField fx:id="txtMileage"
                           promptText="15000"
                           style="-fx-background-color: #060818; -fx-text-fill: #e6f1ff; -fx-prompt-text-fill: #46506f; -fx-border-color: #1a2040; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10 14;"/>
            </VBox>
        </HBox>

        <HBox spacing="16">
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Fuel Type" style="-fx-text-fill: #ccd6f6; -fx-font-size: 12px;"/>
                <ComboBox fx:id="cmbFuelType"
                          promptText="Select fuel"
                          maxWidth="Infinity"/>
            </VBox>

            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Transmission" style="-fx-text-fill: #ccd6f6; -fx-font-size: 12px;"/>
                <ComboBox fx:id="cmbTransmissionType"
                          promptText="Select transmission"
                          maxWidth="Infinity"/>
            </VBox>

            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Category ID *" style="-fx-text-fill: #ccd6f6; -fx-font-size: 12px;"/>
                <TextField fx:id="txtCategoryId"
                           promptText="1"
                           style="-fx-background-color: #060818; -fx-text-fill: #e6f1ff; -fx-prompt-text-fill: #46506f; -fx-border-color: #1a2040; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10 14;"/>
            </VBox>

            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Branch ID *" style="-fx-text-fill: #ccd6f6; -fx-font-size: 12px;"/>
                <TextField fx:id="txtBranchId"
                           promptText="1"
                           style="-fx-background-color: #060818; -fx-text-fill: #e6f1ff; -fx-prompt-text-fill: #46506f; -fx-border-color: #1a2040; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10 14;"/>
            </VBox>
        </HBox>

        <HBox spacing="12" alignment="CENTER_RIGHT">
            <Button text="Cancel"
                    onAction="#handleCancel"
                    style="-fx-background-color: #1a2040;
                           -fx-text-fill: #8892b0;
                           -fx-background-radius: 8;
                           -fx-border-width: 0;
                           -fx-padding: 9 24;
                           -fx-cursor: hand;"/>

            <Button text="💾 Save"
                    onAction="#handleSave"
                    style="-fx-background-color: #3d5af1;
                           -fx-text-fill: white;
                           -fx-font-weight: bold;
                           -fx-background-radius: 8;
                           -fx-border-width: 0;
                           -fx-padding: 9 24;
                           -fx-cursor: hand;"/>
        </HBox>

    </VBox>

    <!-- TABLE تحت الفورم -->
    <TableView fx:id="tableCars"
               VBox.vgrow="ALWAYS"
               style="-fx-background-color: #0d1224;
                      -fx-border-color: #1a2040;
                      -fx-border-radius: 12;
                      -fx-background-radius: 12;
                      -fx-table-cell-border-color: #1a2040;
                      -fx-control-inner-background: #0d1224;
                      -fx-control-inner-background-alt: #0a1020;">

        <columns>
            <TableColumn fx:id="colCarId" text="ID" prefWidth="60"/>
            <TableColumn fx:id="colPlateNumber" text="Plate Number" prefWidth="130"/>
            <TableColumn fx:id="colBrand" text="Brand" prefWidth="120"/>
            <TableColumn fx:id="colModel" text="Model" prefWidth="130"/>
            <TableColumn fx:id="colColor" text="Color" prefWidth="100"/>
            <TableColumn fx:id="colDailyPrice" text="Daily Price" prefWidth="120"/>
            <TableColumn fx:id="colManufactureYear" text="Year" prefWidth="90"/>
            <TableColumn fx:id="colFuelType" text="Fuel" prefWidth="110"/>
            <TableColumn fx:id="colTransmissionType" text="Transmission" prefWidth="130"/>
            <TableColumn fx:id="colMileage" text="Mileage" prefWidth="110"/>
            <TableColumn fx:id="colCategoryId" text="Category ID" prefWidth="110"/>
            <TableColumn fx:id="colBranchId" text="Branch ID" prefWidth="100"/>
        </columns>
    </TableView>

</VBox>