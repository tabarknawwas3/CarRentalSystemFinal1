<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.shape.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="carrentalsystem.controllers.MaintenanceController"
      style="-fx-background-color: #060818; -fx-padding: 28;"
      spacing="16">

    <StackPane prefHeight="210"
               minHeight="210"
               maxHeight="210"
               style="-fx-background-color: #0d1224;
                      -fx-background-radius: 18;
                      -fx-border-color: #1a2040;
                      -fx-border-radius: 18;
                      -fx-border-width: 1;
                      -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.28), 20, 0, 0, 8);">

        <ImageView fitWidth="1120"
                   preserveRatio="true"
                   smooth="true"
                   pickOnBounds="true"
                   StackPane.alignment="CENTER">
            <image>
                <Image url="@images/maintenance-hero.png"/>
            </image>
        </ImageView>

        <Rectangle width="1120"
                   height="210"
                   fill="#050714"
                   opacity="0.40"
                   arcWidth="36"
                   arcHeight="36"/>

        <VBox spacing="22"
              style="-fx-padding: 24 34 24 34;"
              StackPane.alignment="CENTER">

            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox spacing="5">
                    <Label text="Maintenance"
                           style="-fx-font-size: 26px;
                                  -fx-font-weight: bold;
                                  -fx-text-fill: #e6f1ff;"/>

                    <Label text="Track service records, repairs, diagnostics, and vehicle readiness"
                           style="-fx-font-size: 12px;
                                  -fx-text-fill: #c7d2fe;"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <TextField fx:id="txtSearch"
                           promptText="🔍  Search..."
                           onAction="#handleSearch"
                           style="-fx-background-color: rgba(13,18,36,0.88);
                                  -fx-text-fill: #e6f1ff;
                                  -fx-prompt-text-fill: #7783a5;
                                  -fx-border-color: rgba(147,197,253,0.28);
                                  -fx-border-radius: 8;
                                  -fx-background-radius: 8;
                                  -fx-padding: 8 14;
                                  -fx-pref-width: 200;"/>

                <Button text="+ Add"
                        onAction="#handleAdd"
                        style="-fx-background-color: #3d5af1;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-background-radius: 8;
                               -fx-border-width: 0;
                               -fx-padding: 8 18;
                               -fx-cursor: hand;"/>

                <Button text="✏ Edit"
                        onAction="#handleEdit"
                        style="-fx-background-color: rgba(30,58,95,0.90);
                               -fx-text-fill: #93c5fd;
                               -fx-font-weight: bold;
                               -fx-background-radius: 8;
                               -fx-border-width: 0;
                               -fx-padding: 8 18;
                               -fx-cursor: hand;"/>

                <Button text="🗑 Delete"
                        onAction="#handleDelete"
                        style="-fx-background-color: rgba(45,21,21,0.92);
                               -fx-text-fill: #ff6b6b;
                               -fx-font-weight: bold;
                               -fx-background-radius: 8;
                               -fx-border-width: 0;
                               -fx-padding: 8 18;
                               -fx-cursor: hand;"/>
            </HBox>

            <VBox spacing="8">
                <Label text="Smart Vehicle Maintenance"
                       style="-fx-text-fill: white;
                              -fx-font-size: 25px;
                              -fx-font-weight: bold;"/>

                <Label text="Keep your fleet safe and ready with organized service logs and maintenance tracking."
                       wrapText="true"
                       maxWidth="620"
                       style="-fx-text-fill: #c7d2fe;
                              -fx-font-size: 13px;"/>

                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="●"
                           style="-fx-text-fill: #22c55e;
                                  -fx-font-size: 14px;"/>

                    <Label text="Service logs · Diagnostics · Repairs"
                           style="-fx-text-fill: #93c5fd;
                                  -fx-font-size: 12px;"/>
                </HBox>
            </VBox>
        </VBox>
    </StackPane>

    <VBox fx:id="formPanel"
      spacing="14"
      style="-fx-background-color: #0d1224;
             -fx-border-color: #1a2040;
             -fx-border-radius: 12;
             -fx-background-radius: 12;
             -fx-border-width: 1;
             -fx-padding: 20;">

    <Label fx:id="lblFormTitle"
           text="Add New Maintenance Record"
           style="-fx-font-size: 16px;
                  -fx-font-weight: bold;
                  -fx-text-fill: #e6f1ff;"/>

    <HBox spacing="16">
        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label text="Maintenance Type *" style="-fx-text-fill: #ccd6f6; -fx-font-size: 12px;"/>
            <TextField fx:id="txtMaintenanceType"
                       promptText="Oil Change"
                       style="-fx-background-color: #060818;
                              -fx-text-fill: #e6f1ff;
                              -fx-prompt-text-fill: #46506f;
                              -fx-border-color: #1a2040;
                              -fx-border-radius: 8;
                              -fx-background-radius: 8;
                              -fx-padding: 10 14;"/>
        </VBox>

        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label text="Cost" style="-fx-text-fill: #ccd6f6; -fx-font-size: 12px;"/>
            <TextField fx:id="txtMaintenanceCost"
                       promptText="50.00"
                       style="-fx-background-color: #060818;
                              -fx-text-fill: #e6f1ff;
                              -fx-prompt-text-fill: #46506f;
                              -fx-border-color: #1a2040;
                              -fx-border-radius: 8;
                              -fx-background-radius: 8;
                              -fx-padding: 10 14;"/>
        </VBox>

        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label text="Date In *" style="-fx-text-fill: #ccd6f6; -fx-font-size: 12px;"/>
            <DatePicker fx:id="dpDateIn"
                        maxWidth="Infinity"
                        style="-fx-background-color: #060818;
                               -fx-border-color: #1a2040;
                               -fx-border-radius: 8;
                               -fx-background-radius: 8;"/>
        </VBox>

        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label text="Date Out" style="-fx-text-fill: #ccd6f6; -fx-font-size: 12px;"/>
            <DatePicker fx:id="dpDateOut"
                        maxWidth="Infinity"
                        style="-fx-background-color: #060818;
                               -fx-border-color: #1a2040;
                               -fx-border-radius: 8;
                               -fx-background-radius: 8;"/>
        </VBox>
    </HBox>

    <HBox spacing="16">
        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label text="Car ID *" style="-fx-text-fill: #ccd6f6; -fx-font-size: 12px;"/>
            <TextField fx:id="txtCarId"
                       promptText="3"
                       style="-fx-background-color: #060818;
                              -fx-text-fill: #e6f1ff;
                              -fx-prompt-text-fill: #46506f;
                              -fx-border-color: #1a2040;
                              -fx-border-radius: 8;
                              -fx-background-radius: 8;
                              -fx-padding: 10 14;"/>
        </VBox>

        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label text="Employee ID" style="-fx-text-fill: #ccd6f6; -fx-font-size: 12px;"/>
            <TextField fx:id="txtEmployeeId"
                       promptText="2"
                       style="-fx-background-color: #060818;
                              -fx-text-fill: #e6f1ff;
                              -fx-prompt-text-fill: #46506f;
                              -fx-border-color: #1a2040;
                              -fx-border-radius: 8;
                              -fx-background-radius: 8;
                              -fx-padding: 10 14;"/>
        </VBox>
    </HBox>

    <VBox spacing="6">
        <Label text="Description" style="-fx-text-fill: #ccd6f6; -fx-font-size: 12px;"/>
        <TextArea fx:id="txtDescription"
                  promptText="Regular maintenance service"
                  prefRowCount="3"
                  wrapText="true"
                  style="-fx-control-inner-background: #060818;
                         -fx-background-color: #060818;
                         -fx-text-fill: #e6f1ff;
                         -fx-prompt-text-fill: #46506f;
                         -fx-border-color: #1a2040;
                         -fx-border-radius: 8;
                         -fx-background-radius: 8;"/>
    </VBox>

    <HBox spacing="12" alignment="CENTER_RIGHT">
        <Button text="Cancel"
                onAction="#handleCancel"
                style="-fx-background-color: #1a2040;
                       -fx-text-fill: #8892b0;
                       -fx-background-radius: 8;
                       -fx-border-width: 0;
                       -fx-padding: 9 24;
                       -fx-cursor: hand;"/>

        <Button text="💾 Save"
                onAction="#handleSave"
                style="-fx-background-color: #3d5af1;
                       -fx-text-fill: white;
                       -fx-font-weight: bold;
                       -fx-background-radius: 8;
                       -fx-border-width: 0;
                       -fx-padding: 9 24;
                       -fx-cursor: hand;"/>
    </HBox>
</VBox>

    <TableView fx:id="tableMaintenance"
               VBox.vgrow="ALWAYS"
               style="-fx-background-color: #0d1224;
                      -fx-border-color: #1a2040;
                      -fx-border-radius: 12;
                      -fx-background-radius: 12;
                      -fx-table-cell-border-color: #1a2040;
                      -fx-control-inner-background: #0d1224;
                      -fx-control-inner-background-alt: #0a1020;">

        <columns>
            <TableColumn fx:id="colMaintenanceId" text="ID" prefWidth="70"/>
            <TableColumn fx:id="colMaintenanceType" text="Type" prefWidth="150"/>
            <TableColumn fx:id="colDescription" text="Description" prefWidth="260"/>
            <TableColumn fx:id="colMaintenanceCost" text="Cost" prefWidth="100"/>
            <TableColumn fx:id="colDateIn" text="Date In" prefWidth="120"/>
            <TableColumn fx:id="colDateOut" text="Date Out" prefWidth="120"/>
            <TableColumn fx:id="colCarId" text="Car ID" prefWidth="90"/>
            <TableColumn fx:id="colEmployeeId" text="Employee ID" prefWidth="120"/>
        </columns>
    </TableView>
</VBox>