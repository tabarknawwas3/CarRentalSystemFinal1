<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="carrentalsystem.controllers.CustomerRegisterController"
           style="-fx-background-color: #050714; -fx-padding: 28;">

    <VBox spacing="18"
          maxWidth="720"
          style="-fx-background-color: #080b1a;
                 -fx-background-radius: 22;
                 -fx-border-color: #1a2040;
                 -fx-border-radius: 22;
                 -fx-border-width: 1;
                 -fx-padding: 30;">

        <VBox spacing="6">
            <Label text="Create Customer Account"
                   style="-fx-text-fill: white;
                          -fx-font-size: 28px;
                          -fx-font-weight: bold;"/>

            <Label text="Register as a customer to manage your reservations and invoices."
                   style="-fx-text-fill: #8b96b8;
                          -fx-font-size: 13px;"/>
        </VBox>

        <GridPane hgap="14" vgap="12">

            <Label text="First Name *" GridPane.rowIndex="0" GridPane.columnIndex="0"
                   style="-fx-text-fill: #ccd6f6;"/>
            <TextField fx:id="txtFirstName" GridPane.rowIndex="1" GridPane.columnIndex="0"
                       promptText="First name"/>

            <Label text="Last Name *" GridPane.rowIndex="0" GridPane.columnIndex="1"
                   style="-fx-text-fill: #ccd6f6;"/>
            <TextField fx:id="txtLastName" GridPane.rowIndex="1" GridPane.columnIndex="1"
                       promptText="Last name"/>

            <Label text="Date of Birth" GridPane.rowIndex="2" GridPane.columnIndex="0"
                   style="-fx-text-fill: #ccd6f6;"/>
            <DatePicker fx:id="dpDateOfBirth" GridPane.rowIndex="3" GridPane.columnIndex="0"
                        maxWidth="Infinity"/>

            <Label text="Gender *" GridPane.rowIndex="2" GridPane.columnIndex="1"
                   style="-fx-text-fill: #ccd6f6;"/>
            <ComboBox fx:id="cmbGender" GridPane.rowIndex="3" GridPane.columnIndex="1"
                      promptText="Select gender"
                      maxWidth="Infinity"/>

            <Label text="Phone" GridPane.rowIndex="4" GridPane.columnIndex="0"
                   style="-fx-text-fill: #ccd6f6;"/>
            <TextField fx:id="txtPhone" GridPane.rowIndex="5" GridPane.columnIndex="0"
                       promptText="0590000000"/>

            <Label text="Email" GridPane.rowIndex="4" GridPane.columnIndex="1"
                   style="-fx-text-fill: #ccd6f6;"/>
            <TextField fx:id="txtEmail" GridPane.rowIndex="5" GridPane.columnIndex="1"
                       promptText="customer@example.com"/>

            <Label text="Address" GridPane.rowIndex="6" GridPane.columnIndex="0"
                   style="-fx-text-fill: #ccd6f6;"/>
            <TextField fx:id="txtAddress" GridPane.rowIndex="7" GridPane.columnIndex="0"
                       promptText="City"/>

            <Label text="National ID / Passport" GridPane.rowIndex="6" GridPane.columnIndex="1"
                   style="-fx-text-fill: #ccd6f6;"/>
            <TextField fx:id="txtNationalId" GridPane.rowIndex="7" GridPane.columnIndex="1"
                       promptText="ID or Passport"/>

            <Label text="Username *" GridPane.rowIndex="8" GridPane.columnIndex="0"
                   style="-fx-text-fill: #ccd6f6;"/>
            <TextField fx:id="txtUsername" GridPane.rowIndex="9" GridPane.columnIndex="0"
                       promptText="Choose username"/>

            <Label text="Password *" GridPane.rowIndex="8" GridPane.columnIndex="1"
                   style="-fx-text-fill: #ccd6f6;"/>
            <PasswordField fx:id="txtPassword" GridPane.rowIndex="9" GridPane.columnIndex="1"
                           promptText="Choose password"/>

            <columnConstraints>
                <ColumnConstraints percentWidth="50"/>
                <ColumnConstraints percentWidth="50"/>
            </columnConstraints>
        </GridPane>

        <Label fx:id="lblMessage"
               text=""
               visible="false"
               managed="false"
               style="-fx-text-fill: #ff6b6b;
                      -fx-background-color: #2d1515;
                      -fx-background-radius: 8;
                      -fx-padding: 9 12;"/>

        <HBox spacing="12" alignment="CENTER_RIGHT">
            <Button text="Back to Login"
                    onAction="#backToLogin"
                    style="-fx-background-color: #1a2040;
                           -fx-text-fill: #ccd6f6;
                           -fx-background-radius: 10;
                           -fx-padding: 10 20;
                           -fx-cursor: hand;"/>

            <Button text="Create Account"
                    onAction="#handleRegister"
                    style="-fx-background-color: #3d5af1;
                           -fx-text-fill: white;
                           -fx-font-weight: bold;
                           -fx-background-radius: 10;
                           -fx-padding: 10 24;
                           -fx-cursor: hand;"/>
        </HBox>
    </VBox>
</StackPane>