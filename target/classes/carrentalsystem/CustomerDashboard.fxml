<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="carrentalsystem.controllers.CustomerDashboardController"
            style="-fx-background-color: #060818;">

    <!-- TOP HEADER -->
    <top>
        <VBox spacing="14"
              style="-fx-padding: 28 36 14 36; -fx-background-color: #060818;">

            <HBox alignment="CENTER_LEFT">
                <VBox spacing="6">
                    <Label text="Customer Dashboard"
                           style="-fx-text-fill: white;
                                  -fx-font-size: 30px;
                                  -fx-font-weight: bold;"/>

                    <Label fx:id="lblWelcome"
                           text="Welcome"
                           style="-fx-text-fill: #93c5fd;
                                  -fx-font-size: 14px;"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <Button text="Logout"
                        onAction="#handleLogout"
                        style="-fx-background-color: #351515;
                               -fx-text-fill: #ffb4b4;
                               -fx-font-weight: bold;
                               -fx-background-radius: 10;
                               -fx-padding: 10 24;
                               -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </top>

    <!-- LEFT SIDEBAR -->
    <left>
        <VBox prefWidth="315"
              spacing="18"
              style="-fx-padding: 10 20 28 36;
                     -fx-background-color: #060818;">

            <VBox spacing="16"
                  style="-fx-background-color: #0d1224;
                         -fx-background-radius: 18;
                         -fx-border-color: #1a2040;
                         -fx-border-radius: 18;
                         -fx-border-width: 1;
                         -fx-padding: 24;">

                <VBox spacing="8">
                    <Label text="DriveEase"
                           style="-fx-text-fill: white;
                                  -fx-font-size: 25px;
                                  -fx-font-weight: bold;"/>

                    <Label text="Customer Panel"
                           style="-fx-text-fill: #93c5fd;
                                  -fx-font-size: 13px;"/>
                </VBox>

                <Separator style="-fx-background-color: #1a2040;"/>

                <VBox spacing="12">
                    <Label text="My Profile"
                           style="-fx-text-fill: white;
                                  -fx-font-size: 20px;
                                  -fx-font-weight: bold;"/>

                    <Button fx:id="btnProfile"
                            text="Edit Profile"
                            onAction="#handleEditProfile"
                            maxWidth="Infinity"
                            style="-fx-background-color: #1b2350;
                                   -fx-text-fill: #bfdbfe;
                                   -fx-font-weight: bold;
                                   -fx-background-radius: 12;
                                   -fx-padding: 12 18;
                                   -fx-cursor: hand;"/>
                </VBox>

                <Separator style="-fx-background-color: #1a2040;"/>

                <VBox spacing="12">
                    <Label text="Actions"
                           style="-fx-text-fill: white;
                                  -fx-font-size: 20px;
                                  -fx-font-weight: bold;"/>

                    <ScrollPane fitToWidth="true"
            hbarPolicy="NEVER"
            vbarPolicy="AS_NEEDED"
            style="-fx-background: #060818;
                   -fx-background-color: #060818;
                   -fx-border-color: transparent;">
                        <VBox spacing="10"
                              style="-fx-background-color: transparent;
                                     -fx-padding: 0 4 0 0;">

                            <Button fx:id="btnAvailableCars"
                                    text="🚗  Available Cars"
                                    onAction="#handleAvailableCars"
                                    maxWidth="Infinity"
                                    style="-fx-background-color: #1b2350;
                                           -fx-text-fill: #bfdbfe;
                                           -fx-font-weight: bold;
                                           -fx-background-radius: 12;
                                           -fx-padding: 12 18;
                                           -fx-cursor: hand;"/>

                            <Button fx:id="btnMakeReservation"
                                    text="🧾  Make Reservation"
                                    onAction="#handleMakeReservation"
                                    maxWidth="Infinity"
                                    style="-fx-background-color: #1b2350;
                                           -fx-text-fill: #bfdbfe;
                                           -fx-font-weight: bold;
                                           -fx-background-radius: 12;
                                           -fx-padding: 12 18;
                                           -fx-cursor: hand;"/>

                            <Button fx:id="btnMyLicense"
                                    text="🪪  My License"
                                    onAction="#handleMyLicense"
                                    maxWidth="Infinity"
                                    style="-fx-background-color: #1b2350;
                                           -fx-text-fill: #bfdbfe;
                                           -fx-font-weight: bold;
                                           -fx-background-radius: 12;
                                           -fx-padding: 12 18;
                                           -fx-cursor: hand;"/>

                            <Button fx:id="btnMyReservations"
                                    text="📌  My Reservations"
                                    onAction="#handleMyReservations"
                                    maxWidth="Infinity"
                                    style="-fx-background-color: #1b2350;
                                           -fx-text-fill: #bfdbfe;
                                           -fx-font-weight: bold;
                                           -fx-background-radius: 12;
                                           -fx-padding: 12 18;
                                           -fx-cursor: hand;"/>

                            <Button fx:id="btnMyContracts"
                                    text="📄  My Contracts"
                                    onAction="#handleMyContracts"
                                    maxWidth="Infinity"
                                    style="-fx-background-color: #1b2350;
                                           -fx-text-fill: #bfdbfe;
                                           -fx-font-weight: bold;
                                           -fx-background-radius: 12;
                                           -fx-padding: 12 18;
                                           -fx-cursor: hand;"/>

                            <Button fx:id="btnMyInvoices"
                                    text="💳  My Invoices"
                                    onAction="#handleMyInvoices"
                                    maxWidth="Infinity"
                                    style="-fx-background-color: #1b2350;
                                           -fx-text-fill: #bfdbfe;
                                           -fx-font-weight: bold;
                                           -fx-background-radius: 12;
                                           -fx-padding: 12 18;
                                           -fx-cursor: hand;"/>

                            <Button fx:id="btnReviews"
                                    text="⭐  Add Review"
                                    onAction="#handleReviews"
                                    maxWidth="Infinity"
                                    style="-fx-background-color: #1b2350;
                                           -fx-text-fill: #bfdbfe;
                                           -fx-font-weight: bold;
                                           -fx-background-radius: 12;
                                           -fx-padding: 12 18;
                                           -fx-cursor: hand;"/>
                        </VBox>
                    </ScrollPane>
                </VBox>

                <VBox spacing="6"
                      style="-fx-background-color: #111a3d;
                             -fx-background-radius: 14;
                             -fx-border-color: #27346b;
                             -fx-border-radius: 14;
                             -fx-padding: 18;">

                    <Label text="Ready to rent?"
                           style="-fx-text-fill: white;
                                  -fx-font-size: 16px;
                                  -fx-font-weight: bold;"/>

                    <Label text="Start by checking available cars."
                           wrapText="true"
                           style="-fx-text-fill: #93c5fd;
                                  -fx-font-size: 12px;"/>
                </VBox>
            </VBox>
        </VBox>
    </left>

    <!-- CENTER CONTENT -->
    <center>
    <ScrollPane fitToWidth="true"
                hbarPolicy="NEVER"
                vbarPolicy="AS_NEEDED"
                pannable="false"
                style="-fx-background: #060818;
                       -fx-background-color: #060818;
                       -fx-border-color: transparent;">

        <VBox fx:id="mainContent"
              spacing="18"
              prefWidth="1000"
              maxWidth="1000"
              style="-fx-padding: 10 24 36 0;
                     -fx-background-color: #060818;">

            <!-- HERO SECTION -->
            <StackPane fx:id="heroPane"
                       prefHeight="170"
                       prefWidth="1000"
                       maxWidth="1000"
                       style="-fx-background-color: #071020;">

                <ImageView fx:id="heroImage"
                           fitWidth="1000"
                           fitHeight="170"
                           preserveRatio="false"
                           smooth="true">
                    <image>
                        <Image url="@images/customer-welcome-hero.png"/>
                    </image>
                </ImageView>

                <VBox spacing="12"
                      StackPane.alignment="CENTER_LEFT"
                      style="-fx-padding: 28 34;">

                    <Label text="Welcome to DriveEase"
                           style="-fx-text-fill: white;
                                  -fx-font-size: 28px;
                                  -fx-font-weight: bold;"/>

                    <Label text="Book your next rental, manage your license, and track your reservations from one place."
                           wrapText="true"
                           maxWidth="760"
                           style="-fx-text-fill: #e6f1ff;
                                  -fx-font-size: 14px;"/>

                    <Label text="●  Browse cars · Make reservations · View invoices · Add reviews"
                           wrapText="true"
                           maxWidth="760"
                           style="-fx-text-fill: #93c5fd;
                                  -fx-font-size: 13px;"/>
                </VBox>
            </StackPane>

            <!-- DYNAMIC CONTENT AREA -->
            <VBox fx:id="contentArea"
                  spacing="18"
                  prefWidth="1000"
                  maxWidth="1000"
                  style="-fx-background-color: #0d1224;
                         -fx-background-radius: 18;
                         -fx-border-color: #1a2040;
                         -fx-border-radius: 18;
                         -fx-border-width: 1;
                         -fx-padding: 28;">

                <Label fx:id="lblSectionTitle"
                       text="Dashboard Overview"
                       style="-fx-text-fill: white;
                              -fx-font-size: 24px;
                              -fx-font-weight: bold;"/>

                <Label fx:id="lblSectionContent"
                       text="Choose an action from the left menu to manage your rental activities."
                       wrapText="true"
                       maxWidth="900"
                       style="-fx-text-fill: #ccd6f6;
                              -fx-font-size: 14px;
                              -fx-line-spacing: 4;"/>
            </VBox>
        </VBox>
    </ScrollPane>
</center>

</BorderPane>