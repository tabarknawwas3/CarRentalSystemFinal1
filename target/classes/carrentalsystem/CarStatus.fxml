<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.image.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="carrentalsystem.controllers.CarStatusController"
      style="-fx-background-color: #060818; -fx-padding: 28;"
      spacing="16">

    <!-- HERO HEADER WITH BACKGROUND IMAGE -->
    <StackPane prefHeight="210"
               minHeight="210"
               maxHeight="210"
               style="-fx-background-color: #0d1224;
                      -fx-background-radius: 18;
                      -fx-border-color: #1a2040;
                      -fx-border-radius: 18;
                      -fx-border-width: 1;
                      -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.28), 20, 0, 0, 8);">

        <ImageView fitWidth="1120"
                   fitHeight="210"
                   preserveRatio="false"
                   smooth="true"
                   opacity="0.95">
            <image>
                <Image url="@images/car-status-hero.png"/>
            </image>
        </ImageView>

        <Rectangle width="1120"
                   height="210"
                   fill="#050714"
                   opacity="0.48"
                   arcWidth="36"
                   arcHeight="36"/>

        <Rectangle width="1120"
                   height="210"
                   fill="#0b1d4a"
                   opacity="0.20"
                   arcWidth="36"
                   arcHeight="36"/>

        <VBox spacing="22"
              style="-fx-padding: 24 34 24 34;"
              StackPane.alignment="CENTER">

            <HBox alignment="CENTER_LEFT" spacing="12">

                <VBox spacing="5">
                    <Label text="Car Status"
                           style="-fx-font-size: 26px;
                                  -fx-font-weight: bold;
                                  -fx-text-fill: #e6f1ff;"/>

                    <Label text="Track car availability, reservation, rental, and maintenance history"
                           style="-fx-font-size: 12px;
                                  -fx-text-fill: #c7d2fe;"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <TextField fx:id="txtSearch"
                           promptText="🔍  Search..."
                           onAction="#handleSearch"
                           style="-fx-background-color: rgba(13,18,36,0.88);
                                  -fx-text-fill: #e6f1ff;
                                  -fx-prompt-text-fill: #7783a5;
                                  -fx-border-color: rgba(147,197,253,0.28);
                                  -fx-border-radius: 8;
                                  -fx-background-radius: 8;
                                  -fx-padding: 8 14;
                                  -fx-pref-width: 200;"/>

                <Button text="+ Add"
                        onAction="#handleAdd"
                        style="-fx-background-color: #3d5af1;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-background-radius: 8;
                               -fx-border-width: 0;
                               -fx-padding: 8 18;
                               -fx-cursor: hand;"/>

                <Button text="✏ Edit"
                        onAction="#handleEdit"
                        style="-fx-background-color: rgba(30,58,95,0.90);
                               -fx-text-fill: #93c5fd;
                               -fx-font-weight: bold;
                               -fx-background-radius: 8;
                               -fx-border-width: 0;
                               -fx-padding: 8 18;
                               -fx-cursor: hand;"/>

                <Button text="🗑 Delete"
                        onAction="#handleDelete"
                        style="-fx-background-color: rgba(45,21,21,0.92);
                               -fx-text-fill: #ff6b6b;
                               -fx-font-weight: bold;
                               -fx-background-radius: 8;
                               -fx-border-width: 0;
                               -fx-padding: 8 18;
                               -fx-cursor: hand;"/>
            </HBox>

            <VBox spacing="8">
                <Label text="Vehicle Status History"
                       style="-fx-text-fill: white;
                              -fx-font-size: 25px;
                              -fx-font-weight: bold;"/>

                <Label text="Record the car status and the responsible employee who handled the update."
                       wrapText="true"
                       maxWidth="780"
                       style="-fx-text-fill: #c7d2fe;
                              -fx-font-size: 13px;"/>

                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="●"
                           style="-fx-text-fill: #63e6be;
                                  -fx-font-size: 14px;"/>

                    <Label text="Available · Reserved · Rented · Maintenance"
                           style="-fx-text-fill: #93c5fd;
                                  -fx-font-size: 12px;"/>
                </HBox>
            </VBox>

        </VBox>
    </StackPane>

    <!-- FORM فوق الجدول -->
    <VBox fx:id="formPanel"
          spacing="14"
          style="-fx-background-color: #0d1224;
                 -fx-border-color: #1a2040;
                 -fx-border-radius: 12;
                 -fx-background-radius: 12;
                 -fx-border-width: 1;
                 -fx-padding: 20;">

        <Label fx:id="lblFormTitle"
               text="Add New Car Status"
               style="-fx-font-size: 16px;
                      -fx-font-weight: bold;
                      -fx-text-fill: #e6f1ff;"/>

        <HBox spacing="16">
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Car ID *"
                       style="-fx-text-fill: #ccd6f6; -fx-font-size: 12px;"/>

                <TextField fx:id="txtCarId"
                           promptText="1"
                           style="-fx-background-color: #060818;
                                  -fx-text-fill: #e6f1ff;
                                  -fx-prompt-text-fill: #46506f;
                                  -fx-border-color: #1a2040;
                                  -fx-border-radius: 8;
                                  -fx-background-radius: 8;
                                  -fx-padding: 10 14;"/>
            </VBox>

            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Status *"
                       style="-fx-text-fill: #ccd6f6; -fx-font-size: 12px;"/>

                <ComboBox fx:id="cmbStatus"
                          promptText="Select status"
                          maxWidth="Infinity"
                          style="-fx-background-color: #060818;
                                 -fx-border-color: #1a2040;
                                 -fx-border-radius: 8;
                                 -fx-background-radius: 8;
                                 -fx-padding: 4 8;"/>
            </VBox>

            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Responsible Employee ID"
                       style="-fx-text-fill: #ccd6f6; -fx-font-size: 12px;"/>

                <TextField fx:id="txtEmployeeId"
                           promptText="1"
                           style="-fx-background-color: #060818;
                                  -fx-text-fill: #e6f1ff;
                                  -fx-prompt-text-fill: #46506f;
                                  -fx-border-color: #1a2040;
                                  -fx-border-radius: 8;
                                  -fx-background-radius: 8;
                                  -fx-padding: 10 14;"/>
            </VBox>
        </HBox>

        <HBox spacing="16">
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Start Date *"
                       style="-fx-text-fill: #ccd6f6; -fx-font-size: 12px;"/>

                <DatePicker fx:id="dpStartDate"
                            maxWidth="Infinity"
                            style="-fx-background-color: #060818;
                                   -fx-border-color: #1a2040;
                                   -fx-border-radius: 8;
                                   -fx-background-radius: 8;"/>
            </VBox>

            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="End Date"
                       style="-fx-text-fill: #ccd6f6; -fx-font-size: 12px;"/>

                <DatePicker fx:id="dpEndDate"
                            maxWidth="Infinity"
                            style="-fx-background-color: #060818;
                                   -fx-border-color: #1a2040;
                                   -fx-border-radius: 8;
                                   -fx-background-radius: 8;"/>
            </VBox>
        </HBox>

        <HBox spacing="12" alignment="CENTER_RIGHT">
            <Button text="Cancel"
                    onAction="#handleCancel"
                    style="-fx-background-color: #1a2040;
                           -fx-text-fill: #8892b0;
                           -fx-background-radius: 8;
                           -fx-border-width: 0;
                           -fx-padding: 9 24;
                           -fx-cursor: hand;"/>

            <Button text="💾 Save"
                    onAction="#handleSave"
                    style="-fx-background-color: #3d5af1;
                           -fx-text-fill: white;
                           -fx-font-weight: bold;
                           -fx-background-radius: 8;
                           -fx-border-width: 0;
                           -fx-padding: 9 24;
                           -fx-cursor: hand;"/>
        </HBox>

    </VBox>

    <!-- TABLE تحت الفورم -->
    <TableView fx:id="tableCarStatus"
               VBox.vgrow="ALWAYS"
               style="-fx-background-color: #0d1224;
                      -fx-border-color: #1a2040;
                      -fx-border-radius: 12;
                      -fx-background-radius: 12;
                      -fx-table-cell-border-color: #1a2040;
                      -fx-control-inner-background: #0d1224;
                      -fx-control-inner-background-alt: #0a1020;">

        <columns>
            <TableColumn fx:id="colStatusId" text="ID" prefWidth="60"/>
            <TableColumn fx:id="colCarId" text="Car ID" prefWidth="80"/>
            <TableColumn fx:id="colCarInfo" text="Car" prefWidth="240"/>
            <TableColumn fx:id="colStatus" text="Status" prefWidth="130"/>
            <TableColumn fx:id="colStartDate" text="Start Date" prefWidth="130"/>
            <TableColumn fx:id="colEndDate" text="End Date" prefWidth="130"/>
            <TableColumn fx:id="colEmployeeId" text="Responsible Employee ID" prefWidth="170"/>
            <TableColumn fx:id="colEmployeeName" text="Responsible Employee" prefWidth="190"/>
        </columns>
    </TableView>

</VBox>