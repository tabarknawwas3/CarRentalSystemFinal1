<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.image.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="carrentalsystem.controllers.ReportsController"
      style="-fx-background-color: #060818; -fx-padding: 28;"
      spacing="16">

    <!-- HERO HEADER WITH BACKGROUND IMAGE -->
    <StackPane prefHeight="210"
               minHeight="210"
               maxHeight="210"
               style="-fx-background-color: #0d1224;
                      -fx-background-radius: 18;
                      -fx-border-color: #1a2040;
                      -fx-border-radius: 18;
                      -fx-border-width: 1;
                      -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.28), 20, 0, 0, 8);">

        <ImageView fitWidth="1120"
                   fitHeight="210"
                   preserveRatio="false"
                   smooth="true"
                   opacity="0.95">
            <image>
                <Image url="@images/reports-hero.png"/>
            </image>
        </ImageView>

        <Rectangle width="1120"
                   height="210"
                   fill="#050714"
                   opacity="0.48"
                   arcWidth="36"
                   arcHeight="36"/>

        <Rectangle width="1120"
                   height="210"
                   fill="#0b1d4a"
                   opacity="0.20"
                   arcWidth="36"
                   arcHeight="36"/>

        <VBox spacing="22"
              style="-fx-padding: 24 34 24 34;"
              StackPane.alignment="CENTER">

            <HBox alignment="CENTER_LEFT" spacing="12">

                <VBox spacing="5">
                    <Label text="Reports"
                           style="-fx-font-size: 26px;
                                  -fx-font-weight: bold;
                                  -fx-text-fill: #e6f1ff;"/>

                    <Label text="Analyze system performance, fleet activity, revenue, and customer feedback"
                           style="-fx-font-size: 12px;
                                  -fx-text-fill: #c7d2fe;"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <Button text="Generate Report"
                        onAction="#handleGenerateReport"
                        style="-fx-background-color: #3d5af1;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-background-radius: 8;
                               -fx-border-width: 0;
                               -fx-padding: 10 24;
                               -fx-cursor: hand;"/>

                <Button text="Export"
                        onAction="#handleExport"
                        style="-fx-background-color: rgba(30,58,95,0.90);
                               -fx-text-fill: #93c5fd;
                               -fx-font-weight: bold;
                               -fx-background-radius: 8;
                               -fx-border-width: 0;
                               -fx-padding: 10 24;
                               -fx-cursor: hand;"/>
            </HBox>

            <VBox spacing="8">
                <Label text="Analytics and Business Reports"
                       style="-fx-text-fill: white;
                              -fx-font-size: 25px;
                              -fx-font-weight: bold;"/>

                <Label text="View operational summaries, revenue indicators, fleet usage, reservation performance, and review ratings."
                       wrapText="true"
                       maxWidth="860"
                       style="-fx-text-fill: #c7d2fe;
                              -fx-font-size: 13px;"/>

                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="●"
                           style="-fx-text-fill: #63e6be;
                                  -fx-font-size: 14px;"/>

                    <Label text="KPIs · Charts · Insights · Reviews"
                           style="-fx-text-fill: #93c5fd;
                                  -fx-font-size: 12px;"/>
                </HBox>
            </VBox>

        </VBox>
    </StackPane>

    <!-- KPI CARDS -->
    <HBox spacing="16">

        <VBox spacing="8"
              HBox.hgrow="ALWAYS"
              style="-fx-background-color: #0d1224;
                     -fx-border-color: #1a2040;
                     -fx-border-radius: 12;
                     -fx-background-radius: 12;
                     -fx-padding: 20;">

            <Label text="Total Revenue"
                   style="-fx-text-fill: #a8b2d1;
                          -fx-font-size: 12px;"/>

            <Label fx:id="lblTotalRevenue"
                   text="0.00 USD"
                   style="-fx-text-fill: white;
                          -fx-font-size: 28px;
                          -fx-font-weight: bold;"/>

            <Label text="Calculated from paid invoices"
                   style="-fx-text-fill: #63e6be;
                          -fx-font-size: 11px;"/>
        </VBox>

        <VBox spacing="8"
              HBox.hgrow="ALWAYS"
              style="-fx-background-color: #0d1224;
                     -fx-border-color: #1a2040;
                     -fx-border-radius: 12;
                     -fx-background-radius: 12;
                     -fx-padding: 20;">

            <Label text="Active Rentals"
                   style="-fx-text-fill: #a8b2d1;
                          -fx-font-size: 12px;"/>

            <Label fx:id="lblActiveRentals"
                   text="0"
                   style="-fx-text-fill: white;
                          -fx-font-size: 28px;
                          -fx-font-weight: bold;"/>

            <Label text="Currently on road"
                   style="-fx-text-fill: #ff6b6b;
                          -fx-font-size: 11px;"/>
        </VBox>

        <VBox spacing="8"
              HBox.hgrow="ALWAYS"
              style="-fx-background-color: #0d1224;
                     -fx-border-color: #1a2040;
                     -fx-border-radius: 12;
                     -fx-background-radius: 12;
                     -fx-padding: 20;">

            <Label text="Fleet Utilization"
                   style="-fx-text-fill: #a8b2d1;
                          -fx-font-size: 12px;"/>

            <Label fx:id="lblFleetUtilization"
                   text="0.0%"
                   style="-fx-text-fill: white;
                          -fx-font-size: 28px;
                          -fx-font-weight: bold;"/>

            <Label text="Based on active contracts"
                   style="-fx-text-fill: #4f7cff;
                          -fx-font-size: 11px;"/>
        </VBox>

        <VBox spacing="8"
              HBox.hgrow="ALWAYS"
              style="-fx-background-color: #0d1224;
                     -fx-border-color: #1a2040;
                     -fx-border-radius: 12;
                     -fx-background-radius: 12;
                     -fx-padding: 20;">

            <Label text="Average Rating"
                   style="-fx-text-fill: #a8b2d1;
                          -fx-font-size: 12px;"/>

            <Label fx:id="lblAverageRating"
                   text="0.0 / 5"
                   style="-fx-text-fill: white;
                          -fx-font-size: 28px;
                          -fx-font-weight: bold;"/>

            <Label text="Based on customer reviews"
                   style="-fx-text-fill: #facc15;
                          -fx-font-size: 11px;"/>
        </VBox>

    </HBox>

    <!-- TABLE -->
    <TableView fx:id="tableReports"
               VBox.vgrow="ALWAYS"
               style="-fx-background-color: #0d1224;
                      -fx-border-color: #1a2040;
                      -fx-border-radius: 12;
                      -fx-background-radius: 12;
                      -fx-table-cell-border-color: #1a2040;
                      -fx-control-inner-background: #0d1224;
                      -fx-control-inner-background-alt: #0a1020;">

        <columns>
            <TableColumn fx:id="colReportType" text="Report Type" prefWidth="180"/>
            <TableColumn fx:id="colDescription" text="Description" prefWidth="560"/>
            <TableColumn fx:id="colDateRange" text="Date Range" prefWidth="180"/>
            <TableColumn fx:id="colStatus" text="Status" prefWidth="120"/>
        </columns>
    </TableView>

</VBox>