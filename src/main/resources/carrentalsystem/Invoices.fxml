<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.shape.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="carrentalsystem.controllers.InvoicesController"
      style="-fx-background-color: #060818; -fx-padding: 28;"
      spacing="16">

    <StackPane prefHeight="210"
               minHeight="210"
               maxHeight="210"
               style="-fx-background-color: #0d1224;
                      -fx-background-radius: 18;
                      -fx-border-color: #1a2040;
                      -fx-border-radius: 18;
                      -fx-border-width: 1;
                      -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.28), 20, 0, 0, 8);">

        <ImageView fitWidth="1120"
                   preserveRatio="true"
                   smooth="true"
                   pickOnBounds="true"
                   StackPane.alignment="CENTER">
            <image>
                <Image url="@images/invoices-hero.png"/>
            </image>
        </ImageView>

        <Rectangle width="1120"
                   height="210"
                   fill="#050714"
                   opacity="0.40"
                   arcWidth="36"
                   arcHeight="36"/>

        <VBox spacing="22"
              style="-fx-padding: 24 34 24 34;"
              StackPane.alignment="CENTER">

            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox spacing="5">
                    <Label text="Invoices"
                           style="-fx-font-size: 26px;
                                  -fx-font-weight: bold;
                                  -fx-text-fill: #e6f1ff;"/>

                    <Label text="Track payment records, billing details, and invoice status"
                           style="-fx-font-size: 12px;
                                  -fx-text-fill: #c7d2fe;"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <TextField fx:id="txtSearch"
                           promptText="🔍  Search..."
                           onAction="#handleSearch"
                           style="-fx-background-color: rgba(13,18,36,0.88);
                                  -fx-text-fill: #e6f1ff;
                                  -fx-prompt-text-fill: #7783a5;
                                  -fx-border-color: rgba(147,197,253,0.28);
                                  -fx-border-radius: 8;
                                  -fx-background-radius: 8;
                                  -fx-padding: 8 14;
                                  -fx-pref-width: 200;"/>

                <Button text="+ Add"
                        onAction="#handleAdd"
                        style="-fx-background-color: #3d5af1;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-background-radius: 8;
                               -fx-border-width: 0;
                               -fx-padding: 8 18;
                               -fx-cursor: hand;"/>

                <Button text="✏ Edit"
                        onAction="#handleEdit"
                        style="-fx-background-color: rgba(30,58,95,0.90);
                               -fx-text-fill: #93c5fd;
                               -fx-font-weight: bold;
                               -fx-background-radius: 8;
                               -fx-border-width: 0;
                               -fx-padding: 8 18;
                               -fx-cursor: hand;"/>

                <Button text="🗑 Delete"
                        onAction="#handleDelete"
                        style="-fx-background-color: rgba(45,21,21,0.92);
                               -fx-text-fill: #ff6b6b;
                               -fx-font-weight: bold;
                               -fx-background-radius: 8;
                               -fx-border-width: 0;
                               -fx-padding: 8 18;
                               -fx-cursor: hand;"/>
            </HBox>

            <VBox spacing="8">
                <Label text="Invoice and Payment Tracking"
                       style="-fx-text-fill: white;
                              -fx-font-size: 25px;
                              -fx-font-weight: bold;"/>

                <Label text="Monitor customer payments, invoice totals, and financial records for completed rentals."
                       wrapText="true"
                       maxWidth="620"
                       style="-fx-text-fill: #c7d2fe;
                              -fx-font-size: 13px;"/>

                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="●"
                           style="-fx-text-fill: #38bdf8;
                                  -fx-font-size: 14px;"/>

                    <Label text="Billing · Receipts · Payment history"
                           style="-fx-text-fill: #93c5fd;
                                  -fx-font-size: 12px;"/>
                </HBox>
            </VBox>
        </VBox>
    </StackPane>

    <VBox fx:id="formPanel"
      spacing="14"
      style="-fx-background-color: #0d1224;
             -fx-border-color: #1a2040;
             -fx-border-radius: 12;
             -fx-background-radius: 12;
             -fx-border-width: 1;
             -fx-padding: 20;">

    <Label fx:id="lblFormTitle"
           text="Add New Invoice"
           style="-fx-font-size: 16px;
                  -fx-font-weight: bold;
                  -fx-text-fill: #e6f1ff;"/>

    <HBox spacing="16">
        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label text="Issue Date *" style="-fx-text-fill: #ccd6f6; -fx-font-size: 12px;"/>
            <DatePicker fx:id="dpIssueDate"
                        maxWidth="Infinity"
                        style="-fx-background-color: #060818;
                               -fx-border-color: #1a2040;
                               -fx-border-radius: 8;
                               -fx-background-radius: 8;"/>
        </VBox>

        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label text="Rental Cost" style="-fx-text-fill: #ccd6f6; -fx-font-size: 12px;"/>
            <TextField fx:id="txtRentalCost"
                       promptText="140.00"
                       onKeyReleased="#handleCalculateTotal"
                       style="-fx-background-color: #060818;
                              -fx-text-fill: #e6f1ff;
                              -fx-prompt-text-fill: #46506f;
                              -fx-border-color: #1a2040;
                              -fx-border-radius: 8;
                              -fx-background-radius: 8;
                              -fx-padding: 10 14;"/>
        </VBox>

        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label text="Extra Charges" style="-fx-text-fill: #ccd6f6; -fx-font-size: 12px;"/>
            <TextField fx:id="txtExtraCharges"
                       promptText="8.00"
                       onKeyReleased="#handleCalculateTotal"
                       style="-fx-background-color: #060818;
                              -fx-text-fill: #e6f1ff;
                              -fx-prompt-text-fill: #46506f;
                              -fx-border-color: #1a2040;
                              -fx-border-radius: 8;
                              -fx-background-radius: 8;
                              -fx-padding: 10 14;"/>
        </VBox>
    </HBox>

    <HBox spacing="16">
        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label text="Late Fees" style="-fx-text-fill: #ccd6f6; -fx-font-size: 12px;"/>
            <TextField fx:id="txtLateFees"
                       promptText="0.00"
                       onKeyReleased="#handleCalculateTotal"
                       style="-fx-background-color: #060818;
                              -fx-text-fill: #e6f1ff;
                              -fx-prompt-text-fill: #46506f;
                              -fx-border-color: #1a2040;
                              -fx-border-radius: 8;
                              -fx-background-radius: 8;
                              -fx-padding: 10 14;"/>
        </VBox>

        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label text="Discount" style="-fx-text-fill: #ccd6f6; -fx-font-size: 12px;"/>
            <TextField fx:id="txtDiscount"
                       promptText="5.00"
                       onKeyReleased="#handleCalculateTotal"
                       style="-fx-background-color: #060818;
                              -fx-text-fill: #e6f1ff;
                              -fx-prompt-text-fill: #46506f;
                              -fx-border-color: #1a2040;
                              -fx-border-radius: 8;
                              -fx-background-radius: 8;
                              -fx-padding: 10 14;"/>
        </VBox>

        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label text="Tax" style="-fx-text-fill: #ccd6f6; -fx-font-size: 12px;"/>
            <TextField fx:id="txtTax"
                       promptText="19.95"
                       onKeyReleased="#handleCalculateTotal"
                       style="-fx-background-color: #060818;
                              -fx-text-fill: #e6f1ff;
                              -fx-prompt-text-fill: #46506f;
                              -fx-border-color: #1a2040;
                              -fx-border-radius: 8;
                              -fx-background-radius: 8;
                              -fx-padding: 10 14;"/>
        </VBox>
    </HBox>

    <HBox spacing="16">
        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label text="Total Amount" style="-fx-text-fill: #ccd6f6; -fx-font-size: 12px;"/>
            <TextField fx:id="txtTotalAmount"
                       promptText="162.95"
                       style="-fx-background-color: #060818;
                              -fx-text-fill: #e6f1ff;
                              -fx-prompt-text-fill: #46506f;
                              -fx-border-color: #1a2040;
                              -fx-border-radius: 8;
                              -fx-background-radius: 8;
                              -fx-padding: 10 14;"/>
        </VBox>

        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label text="Status *" style="-fx-text-fill: #ccd6f6; -fx-font-size: 12px;"/>
            <ComboBox fx:id="cmbInvoiceStatus"
                      promptText="Select status"
                      maxWidth="Infinity"
                      style="-fx-background-color: #060818;
                             -fx-border-color: #1a2040;
                             -fx-border-radius: 8;
                             -fx-background-radius: 8;
                             -fx-padding: 4 8;"/>
        </VBox>

        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label text="Contract ID *" style="-fx-text-fill: #ccd6f6; -fx-font-size: 12px;"/>
            <TextField fx:id="txtContractId"
                       promptText="1"
                       style="-fx-background-color: #060818;
                              -fx-text-fill: #e6f1ff;
                              -fx-prompt-text-fill: #46506f;
                              -fx-border-color: #1a2040;
                              -fx-border-radius: 8;
                              -fx-background-radius: 8;
                              -fx-padding: 10 14;"/>
        </VBox>
    </HBox>

    <HBox spacing="12" alignment="CENTER_RIGHT">
        <Button text="Cancel"
                onAction="#handleCancel"
                style="-fx-background-color: #1a2040;
                       -fx-text-fill: #8892b0;
                       -fx-background-radius: 8;
                       -fx-border-width: 0;
                       -fx-padding: 9 24;
                       -fx-cursor: hand;"/>

        <Button text="💾 Save"
                onAction="#handleSave"
                style="-fx-background-color: #3d5af1;
                       -fx-text-fill: white;
                       -fx-font-weight: bold;
                       -fx-background-radius: 8;
                       -fx-border-width: 0;
                       -fx-padding: 9 24;
                       -fx-cursor: hand;"/>
    </HBox>
</VBox>

    <TableView fx:id="tableInvoices"
               VBox.vgrow="ALWAYS"
               style="-fx-background-color: #0d1224;
                      -fx-border-color: #1a2040;
                      -fx-border-radius: 12;
                      -fx-background-radius: 12;
                      -fx-table-cell-border-color: #1a2040;
                      -fx-control-inner-background: #0d1224;
                      -fx-control-inner-background-alt: #0a1020;">

        <columns>
            <TableColumn fx:id="colInvoiceId" text="ID" prefWidth="60"/>
            <TableColumn fx:id="colIssueDate" text="Issue Date" prefWidth="110"/>
            <TableColumn fx:id="colRentalCost" text="Rental Cost" prefWidth="110"/>
            <TableColumn fx:id="colExtraCharges" text="Extra Charges" prefWidth="120"/>
            <TableColumn fx:id="colLateFees" text="Late Fees" prefWidth="100"/>
            <TableColumn fx:id="colDiscount" text="Discount" prefWidth="100"/>
            <TableColumn fx:id="colTax" text="Tax" prefWidth="90"/>
            <TableColumn fx:id="colTotalAmount" text="Total" prefWidth="110"/>
            <TableColumn fx:id="colInvoiceStatus" text="Status" prefWidth="120"/>
            <TableColumn fx:id="colContractId" text="Contract ID" prefWidth="110"/>
        </columns>
    </TableView>
</VBox>