<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.shape.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="carrentalsystem.controllers.DashboardHomeController"
      style="-fx-background-color: #060818; -fx-padding: 28;"
      spacing="18"
      VBox.vgrow="ALWAYS">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT">
        <VBox spacing="4">
            <Label text="Dashboard"
                   style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #e6f1ff;"/>

            <Label text="Overview of your car rental system performance"
                   style="-fx-font-size: 12px; -fx-text-fill: #8892b0;"/>
        </VBox>
    </HBox>

    <!-- Hero Banner -->
    <StackPane prefHeight="190"
               minHeight="190"
               maxHeight="190"
               style="-fx-background-color: #0d1224;
                      -fx-background-radius: 18;
                      -fx-border-color: #1a2040;
                      -fx-border-radius: 18;
                      -fx-border-width: 1;
                      -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.28), 20, 0, 0, 8);">

        <!-- Hero image: not stretched -->
        <ImageView fitWidth="1120"
                   preserveRatio="true"
                   smooth="true"
                   pickOnBounds="true"
                   StackPane.alignment="CENTER">
            <image>
                <Image url="@images/dashboard-hero.png"/>
            </image>
        </ImageView>

        <!-- Soft dark overlay -->
        <Rectangle width="1120"
                   height="190"
                   fill="#050714"
                   opacity="0.30"
                   arcWidth="36"
                   arcHeight="36"/>

        <!-- Hero text -->
        <HBox alignment="CENTER_LEFT"
              style="-fx-padding: 0 34;"
              StackPane.alignment="CENTER_LEFT">

            <VBox spacing="8">
                <Label text="Welcome to DriveEase"
                       style="-fx-text-fill: white;
                              -fx-font-size: 28px;
                              -fx-font-weight: bold;"/>

                <Label text="Manage customers, vehicles, reservations, contracts, and invoices from one premium dashboard."
                       wrapText="true"
                       maxWidth="520"
                       style="-fx-text-fill: #c7d2fe;
                              -fx-font-size: 13px;"/>

                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="●"
                           style="-fx-text-fill: #3d5af1; -fx-font-size: 14px;"/>
                    <Label text="Live fleet overview"
                           style="-fx-text-fill: #93c5fd; -fx-font-size: 12px;"/>
                </HBox>
            </VBox>
        </HBox>
    </StackPane>

    <!-- Stats Cards -->
    <HBox spacing="16">

        <VBox style="-fx-background-color: #0d1224;
                     -fx-border-color: #1a2040;
                     -fx-border-radius: 12;
                     -fx-background-radius: 12;
                     -fx-border-width: 1;
                     -fx-padding: 20;"
              prefWidth="200">

            <Label text="👥 Customers"
                   style="-fx-text-fill: #8892b0; -fx-font-size: 12px;"/>

            <Label fx:id="lblTotalCustomers"
                   text="0"
                   style="-fx-text-fill: #e6f1ff;
                          -fx-font-size: 32px;
                          -fx-font-weight: bold;"/>

            <Label text="Total registered"
                   style="-fx-text-fill: #3d5af1; -fx-font-size: 11px;"/>
        </VBox>

        <VBox style="-fx-background-color: #0d1224;
                     -fx-border-color: #1a2040;
                     -fx-border-radius: 12;
                     -fx-background-radius: 12;
                     -fx-border-width: 1;
                     -fx-padding: 20;"
              prefWidth="200">

            <Label text="🚗 Cars"
                   style="-fx-text-fill: #8892b0; -fx-font-size: 12px;"/>

            <Label fx:id="lblTotalCars"
                   text="0"
                   style="-fx-text-fill: #e6f1ff;
                          -fx-font-size: 32px;
                          -fx-font-weight: bold;"/>

            <Label text="In fleet"
                   style="-fx-text-fill: #34d399; -fx-font-size: 11px;"/>
        </VBox>

        <VBox style="-fx-background-color: #0d1224;
                     -fx-border-color: #1a2040;
                     -fx-border-radius: 12;
                     -fx-background-radius: 12;
                     -fx-border-width: 1;
                     -fx-padding: 20;"
              prefWidth="200">

            <Label text="📋 Reservations"
                   style="-fx-text-fill: #8892b0; -fx-font-size: 12px;"/>

            <Label fx:id="lblTotalReservations"
                   text="0"
                   style="-fx-text-fill: #e6f1ff;
                          -fx-font-size: 32px;
                          -fx-font-weight: bold;"/>

            <Label text="Total bookings"
                   style="-fx-text-fill: #fbbf24; -fx-font-size: 11px;"/>
        </VBox>

        <VBox style="-fx-background-color: #0d1224;
                     -fx-border-color: #1a2040;
                     -fx-border-radius: 12;
                     -fx-background-radius: 12;
                     -fx-border-width: 1;
                     -fx-padding: 20;"
              prefWidth="200">

            <Label text="📄 Contracts"
                   style="-fx-text-fill: #8892b0; -fx-font-size: 12px;"/>

            <Label fx:id="lblTotalContracts"
                   text="0"
                   style="-fx-text-fill: #e6f1ff;
                          -fx-font-size: 32px;
                          -fx-font-weight: bold;"/>

            <Label text="Active rentals"
                   style="-fx-text-fill: #f87171; -fx-font-size: 11px;"/>
        </VBox>

    </HBox>

    <!-- Recent Customers -->
    <VBox VBox.vgrow="ALWAYS"
          style="-fx-background-color: #0d1224;
                 -fx-border-color: #1a2040;
                 -fx-border-radius: 12;
                 -fx-background-radius: 12;
                 -fx-border-width: 1;">

        <HBox style="-fx-padding: 16 20 16 20;
                     -fx-border-color: #1a2040;
                     -fx-border-width: 0 0 1 0;">

            <Label text="Recent Customers"
                   style="-fx-text-fill: #e6f1ff;
                          -fx-font-size: 14px;
                          -fx-font-weight: bold;"/>
        </HBox>

        <TableView fx:id="tableCustomers"
                   VBox.vgrow="ALWAYS"
                   style="-fx-background-color: #0d1224;
                          -fx-border-width: 0;
                          -fx-table-cell-border-color: #1a2040;
                          -fx-control-inner-background: #0d1224;
                          -fx-control-inner-background-alt: #0a1020;">

            <columns>
                <TableColumn fx:id="colId"
                             text="ID"
                             prefWidth="60"/>

                <TableColumn fx:id="colFirstName"
                             text="First Name"
                             prefWidth="150"/>

                <TableColumn fx:id="colLastName"
                             text="Last Name"
                             prefWidth="150"/>

                <TableColumn fx:id="colPhone"
                             text="Phone"
                             prefWidth="160"/>

                <TableColumn fx:id="colEmail"
                             text="Email"
                             prefWidth="240"/>

                <TableColumn fx:id="colGender"
                             text="Gender"
                             prefWidth="100"/>
            </columns>
        </TableView>
    </VBox>

</VBox>